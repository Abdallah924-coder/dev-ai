# ══════════════════════════════════════
# DEVAI — WORLDIFYAI  |  Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# NE JAMAIS commiter le fichier .env sur Git !
# ══════════════════════════════════════

# ── Serveur ──
PORT=5000
NODE_ENV=production

# ── MongoDB Atlas ──
# Obtenez votre URI sur https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/devai?retryWrites=true&w=majority

# ── JWT ──
# Générez une clé secrète forte : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=votre_secret_jwt_tres_long_et_aleatoire
JWT_EXPIRES_IN=30d
ADMIN_JWT_SECRET=votre_secret_admin_optionnel
ADMIN_PASSWORD=choisissez_un_mot_de_passe_admin_solide

# ── API Anthropic (Claude) ──
# Obtenez votre clé sur https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Recherche web optionnelle (Deep Research) ──
# Fournisseur actuel supporté : Tavily
WEB_RESEARCH_ENABLED=false
WEB_RESEARCH_PROVIDER=tavily
TAVILY_API_KEY=tvly-...
# ── Email (pour réinitialisation mot de passe) ──
# Option 1 recommandée sur Render : Brevo HTTP API
BREVO_API_KEY=xkeysib-votre-cle-brevo
# Optionnel si vous voulez pointer vers un endpoint HTTP différent
BREVO_API_URL=https://api.brevo.com/v3/smtp/email

# Option 2 : SMTP classique (utile en local ou si vous n'utilisez pas Brevo)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=votre-email@gmail.com
EMAIL_PASS=votre_mot_de_passe_application

# Adresse affichée comme expéditeur
EMAIL_FROM=DevAI <noreply@worldifyai.com>

# Boîte qui reçoit les messages de contact et les notifications admin
CONTACT_RECEIVER_EMAIL=votre-boite-admin@gmail.com

# OTP e-mail
EMAIL_OTP_LENGTH=6
EMAIL_OTP_TTL_MINUTES=10

# ── URL Frontend (pour les liens dans les emails) ──
FRONTEND_URL=http://localhost:3000

# ── CORS ──
# URL(s) de votre frontend séparées par des virgules
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
